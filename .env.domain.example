# Reverse-proxy deployment settings.
# Ports and frontend serving mode are fixed by docker-compose.domain.yml:
# Nginx proxies to 127.0.0.1:18080.
MASTER_SERVER_LLM_PROVIDER=https://api.openai.com/v1/chat/completions
MASTER_SERVER_LLM_MODEL=gpt-5.4
MASTER_SERVER_LLM_API_KEY=

# QQ bot credentials: required only when deploying with --profile qq-bot.
QQ_APP_ID=
QQ_APP_SECRET=
