# Reverse-proxy deployment defaults
MASTER_SERVER_FRONTEND_PORT=18080
MASTER_SERVER_BACKEND_PORT=18081
MASTER_SERVER_LOG_LEVEL=INFO
MASTER_SERVER_SERVE_BUILT_FRONTEND=1
MASTER_SERVER_DISABLE_FRONTEND=1

# Optional runtime settings
# MASTER_SERVER_LLM_PROVIDER=https://api.openai.com/v1/chat/completions
# MASTER_SERVER_LLM_MODEL=gpt-5.4
# MASTER_SERVER_LLM_API_KEY=

# Optional Docker build mirrors
# MASTER_SERVER_APT_MIRROR_BASE=https://mirrors.tuna.tsinghua.edu.cn
# MASTER_SERVER_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# MASTER_SERVER_NPM_REGISTRY=https://registry.npmmirror.com
