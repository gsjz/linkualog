# Runtime: usually only these three need attention.
MASTER_SERVER_LLM_PROVIDER=https://api.openai.com/v1/chat/completions
MASTER_SERVER_LLM_MODEL=gpt-5.4
MASTER_SERVER_LLM_API_KEY=

# QQ bot runtime: required by ./deploy.sh
QQ_APP_ID=
QQ_APP_SECRET=
QQ_INTENTS=33554432
QQ_SHARD_ID=0
QQ_SHARD_COUNT=1
QQ_RUN_SECONDS=0
QQ_LLM_ROUTE_ENABLED=1
QQ_LLM_ROUTE_CONFIDENCE=0.72
QQ_ADD_FETCH_LLM=0

# Optional runtime ports.
# Leave FRONTEND empty to use 8000 for local manual run, or 80 for Docker/Compose.
MASTER_SERVER_FRONTEND_PORT=
MASTER_SERVER_BACKEND_PORT=8080
MASTER_SERVER_LOG_LEVEL=INFO

# Docker build mirrors.
# The defaults below are usable in mainland China and can be adjusted when needed.
MASTER_SERVER_APT_MIRROR_BASE=https://mirrors.tuna.tsinghua.edu.cn
MASTER_SERVER_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
MASTER_SERVER_NPM_REGISTRY=https://registry.npmmirror.com
QQ_BOT_APT_MIRROR_BASE=https://mirrors.tuna.tsinghua.edu.cn
QQ_BOT_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Advanced refine/review tuning is intentionally omitted here.
# If you really need it, use the UI config page or master-server/local_data/llm_config.json.
