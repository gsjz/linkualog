# Shared LLM config for master-server
MASTER_SERVER_LLM_PROVIDER=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MASTER_SERVER_LLM_MODEL=qwen3.5-flash
MASTER_SERVER_LLM_API_KEY=
MASTER_SERVER_FRONTEND_PORT=80
MASTER_SERVER_BACKEND_PORT=8080

# Shared LLM config for review-agent (review-server)
REVIEW_SERVER_LLM_PROVIDER=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
REVIEW_SERVER_LLM_MODEL=qwen3.5-flash
REVIEW_SERVER_LLM_API_KEY=
REVIEW_SERVER_LLM_TIMEOUT_SECONDS=75
REVIEW_SERVER_FOLDER_MERGE_LLM_TIMEOUT_SECONDS=90
REVIEW_SERVER_FOLDER_MERGE_LLM_MAX_TOKENS=900
REVIEW_SERVER_FOLDER_MERGE_LLM_MAX_TOKENS_CAP=3200
REVIEW_SERVER_FOLDER_MERGE_MAX_SUGGESTIONS=40
REVIEW_SERVER_FOLDER_MERGE_TEMPERATURE=0
REVIEW_SERVER_FOLDER_MERGE_WORD_LIMIT=200
REVIEW_SERVER_LLM_CONNECTIVITY_CHECK=1
REVIEW_SERVER_LLM_CONNECTIVITY_TIMEOUT_SECONDS=3
REVIEW_SERVER_LLM_CONNECTIVITY_STRICT=0
REVIEW_SERVER_LLM_CONNECTIVITY_PROBE_TTL_SECONDS=180
REVIEW_SERVER_LLM_REQUEST_MAX_RETRIES=2
REVIEW_SERVER_LLM_REQUEST_RETRY_BACKOFF_SECONDS=1
REVIEW_SERVER_LOG_LEVEL=INFO
REVIEW_SERVER_FRONTEND_PORT=8091
REVIEW_SERVER_BACKEND_PORT=8090
# REVIEW_SERVER_DISABLE_FRONTEND=1
