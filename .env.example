# Shared LLM config for master-server
MASTER_SERVER_LLM_PROVIDER=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MASTER_SERVER_LLM_MODEL=qwen3.5-flash
MASTER_SERVER_LLM_API_KEY=
# 留空时：
# - 非 Docker 运行默认前端端口为 8000
# - Docker/Compose 运行默认前端端口为 80
MASTER_SERVER_FRONTEND_PORT=
MASTER_SERVER_BACKEND_PORT=8080
# MASTER_SERVER_DISABLE_FRONTEND=1
MASTER_SERVER_EXPERIMENTAL_COORDINATES_ENABLED=0
MASTER_SERVER_LOG_LEVEL=INFO

# Review / refine logic is now part of master-server.
MASTER_SERVER_REVIEW_LLM_TIMEOUT_SECONDS=75
MASTER_SERVER_REVIEW_FOLDER_MERGE_LLM_TIMEOUT_SECONDS=90
MASTER_SERVER_REVIEW_FOLDER_MERGE_LLM_MAX_TOKENS=900
MASTER_SERVER_REVIEW_FOLDER_MERGE_LLM_MAX_TOKENS_CAP=3200
MASTER_SERVER_REVIEW_FOLDER_MERGE_MAX_SUGGESTIONS=40
MASTER_SERVER_REVIEW_FOLDER_MERGE_TEMPERATURE=0
MASTER_SERVER_REVIEW_FOLDER_MERGE_WORD_LIMIT=200
MASTER_SERVER_REVIEW_LLM_CONNECTIVITY_CHECK=1
MASTER_SERVER_REVIEW_LLM_CONNECTIVITY_TIMEOUT_SECONDS=3
MASTER_SERVER_REVIEW_LLM_CONNECTIVITY_STRICT=0
MASTER_SERVER_REVIEW_LLM_CONNECTIVITY_PROBE_TTL_SECONDS=180
MASTER_SERVER_REVIEW_LLM_REQUEST_MAX_RETRIES=2
MASTER_SERVER_REVIEW_LLM_REQUEST_RETRY_BACKOFF_SECONDS=1
