# User-facing runtime settings.
# Operational defaults such as ports, gateway intents, shards, run limits,
# and build mirrors are intentionally kept out of this template.
MASTER_SERVER_LLM_PROVIDER=https://api.openai.com/v1/chat/completions
MASTER_SERVER_LLM_MODEL=gpt-5.4
MASTER_SERVER_LLM_API_KEY=

# QQ bot credentials: required only for ./deploy.sh or --profile qq-bot.
QQ_APP_ID=
QQ_APP_SECRET=
